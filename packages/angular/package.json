{
  "name": "oidc-js-angular",
  "version": "1.0.2",
  "description": "Simple OIDC authentication for Angular. Signals, DI, and route guards with zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "oidc",
    "openid",
    "oauth2",
    "angular",
    "authentication"
  ],
  "author": "eugenioenko",
  "license": "MIT",
  "dependencies": {
    "oidc-js": "workspace:*",
    "oidc-js-core": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "@angular/router": ">=17.0.0"
  },
  "devDependencies": {
    "@angular/core": "^19.0.0",
    "@angular/router": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.0",
    "jsdom": "^26.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eugenioenko/oidc-js.git",
    "directory": "packages/angular"
  },
  "homepage": "https://eugenioenko.github.io/oidc-js/"
}
