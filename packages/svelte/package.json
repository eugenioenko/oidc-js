{
  "name": "oidc-js-svelte",
  "version": "1.0.2",
  "description": "Simple OIDC authentication for Svelte 5. Context, runes, and auth guards with zero dependencies.",
  "type": "module",
  "svelte": "./dist/index.js",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "oidc",
    "openid",
    "oauth2",
    "svelte",
    "authentication"
  ],
  "author": "eugenioenko",
  "license": "MIT",
  "dependencies": {
    "oidc-js": "workspace:*",
    "oidc-js-core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
